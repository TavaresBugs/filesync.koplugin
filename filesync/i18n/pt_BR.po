# Portuguese (Brazil) translations for FileSync KOReader plugin
msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"
"Language: pt_BR\n"

msgid "FileSync"
msgstr "FileSync"

msgid "FileSync - Wireless File Manager"
msgstr "FileSync - Gerenciador de Arquivos Sem Fio"

msgid "Launches a local HTTP web server and displays a QR code. Scan with your phone to manage books and files on your device wirelessly through a clean web interface."
msgstr "Inicia um servidor web HTTP local e exibe um código QR. Escaneie com seu celular para gerenciar livros e arquivos no dispositivo sem fio por meio de uma interface web limpa."

msgid "Stop file server"
msgstr "Parar servidor de arquivos"

msgid "Start file server"
msgstr "Iniciar servidor de arquivos"

msgid "Server status"
msgstr "Status do servidor"

msgid "Server port"
msgstr "Porta do servidor"

msgid "Safe mode"
msgstr "Modo seguro"

msgid "Show QR code"
msgstr "Mostrar código QR"

msgid "Check for updates"
msgstr "Verificar atualizações"

msgid "About"
msgstr "Sobre"

msgid "FileSync v1.0.0\n\nWireless file manager for KOReader.\n\nStart the server, scan the QR code with your phone, and manage your books from any browser on the same WiFi network."
msgstr "FileSync v1.0.0\n\nGerenciador de arquivos sem fio para KOReader.\n\nInicie o servidor, escaneie o código QR com seu celular e gerencie seus arquivos de qualquer navegador na mesma rede Wi-Fi."

msgid "FileSync v1.0.0\n\nWireless file manager for KOReader.\n\nStart the server, scan the QR code with your phone, and manage your books from any browser on the same WiFi network.\n\nProject:\ngithub.com/abrahamnm/filesync.koplugin"
msgstr "FileSync v1.0.0\n\nGerenciador de arquivos sem fio para KOReader.\n\nInicie o servidor, escaneie o código QR com seu celular e gerencie seus arquivos de qualquer navegador na mesma rede Wi-Fi.\n\nProjeto:\ngithub.com/abrahamnm/filesync.koplugin"

msgid "Cancel"
msgstr "Cancelar"

msgid "Save"
msgstr "Salvar"

msgid "Port set to %1. Restart the server for changes to take effect."
msgstr "Porta configurada para %1. Reinicie o servidor para que as mudanças tenham efeito."

msgid "Invalid port. Please enter a number between 1 and 65535."
msgstr "Porta inválida. Insira um número entre 1 e 65535."

msgid "FileSync server is already running."
msgstr "O servidor FileSync já está em execução."

msgid "WiFi is not enabled. Please turn on WiFi first."
msgstr "O Wi-Fi está desativado. Ative o Wi-Fi primeiro."

msgid "Could not determine device IP address. Make sure WiFi is connected."
msgstr "Não foi possível identificar o endereço IP do dispositivo. Certifique-se de que o Wi-Fi está conectado."

msgid "Failed to start server: %1"
msgstr "Erro ao iniciar o servidor: %1"

msgid "FileSync server stopped."
msgstr "Servidor FileSync parado."

msgid "Low Battery"
msgstr "Bateria fraca"

msgid "Battery level is at %1%. Running the server may drain the battery quickly."
msgstr "O nível da bateria está em %1%. Executar o servidor pode consumir a bateria rapidamente."

msgid "Start Anyway"
msgstr "Iniciar mesmo assim"

msgid "Server is not running."
msgstr "O servidor não está em execução."

msgid "Scan the QR code or enter the URL\nin your browser.\n\nBoth devices must be on the same WiFi network."
msgstr "Escaneie o código QR ou digite a URL\nno navegador.\n\nAmbos os dispositivos devem estar na mesma rede Wi-Fi."

msgid "Stop Server"
msgstr "Parar servidor"

msgid "Stopping server..."
msgstr "Parando servidor..."

msgid "Server running in the background. Stop the server to save battery."
msgstr "Servidor em execução em segundo plano. Pare o servidor para economizar bateria."

msgid "Image preview"
msgstr "Prévia de imagem"

msgid "Network error: could not reach GitHub."
msgstr "Erro de rede: não foi possível acessar o GitHub."

msgid "GitHub API returned status %1."
msgstr "A API do GitHub retornou o status %1."

msgid "Failed to parse update information from GitHub."
msgstr "Falha ao processar as informações de atualização do GitHub."

msgid "Download failed: network error."
msgstr "Falha no download: erro de rede."

msgid "Cannot create temporary file: %1"
msgstr "Não foi possível criar arquivo temporário: %1"

msgid "Download failed with status %1."
msgstr "Falha no download com status %1."

msgid "Cannot determine plugin parent directory."
msgstr "Não foi possível determinar o diretório pai do plugin."

msgid "Update verification failed: extracted files do not look like a valid plugin."
msgstr "Falha na verificação da atualização: os arquivos extraídos não parecem um plugin válido."

msgid "Failed to install update. Previous version has been restored."
msgstr "Falha ao instalar a atualização. A versão anterior foi restaurada."

msgid "WiFi is not enabled. Please turn on WiFi and try again."
msgstr "O Wi-Fi não está ativado. Ative o Wi-Fi e tente novamente."

msgid "Checking for updates..."
msgstr "Verificando atualizações..."

msgid "Could not check for updates.\n\n%1"
msgstr "Não foi possível verificar atualizações.\n\n%1"

msgid "Could not determine the latest version."
msgstr "Não foi possível determinar a versão mais recente."

msgid "FileSync is up to date (v%1)."
msgstr "O FileSync está atualizado (v%1)."

msgid "A new version of FileSync is available!\n\nCurrent: v%1\nNew: v%2"
msgstr "Uma nova versão do FileSync está disponível!\n\nAtual: v%1\nNova: v%2"

msgid "Update now"
msgstr "Atualizar agora"

msgid "Later"
msgstr "Depois"

msgid "Could not find a download URL for this release."
msgstr "Não foi possível encontrar uma URL de download para esta versão."

msgid "Downloading update..."
msgstr "Baixando atualização..."

msgid "Download failed.\n\n%1"
msgstr "Falha no download.\n\n%1"

msgid "Installing update..."
msgstr "Instalando atualização..."

msgid "FileSync has been updated successfully!\n\nPlease restart KOReader for the changes to take effect."
msgstr "O FileSync foi atualizado com sucesso!\n\nReinicie o KOReader para que as alterações tenham efeito."

msgid "Restart now"
msgstr "Reiniciar agora"

msgid "Define Root PIN"
msgstr "Definir PIN Root"

msgid "Change Root PIN"
msgstr "Alterar PIN Root"

msgid "Reveal Root PIN"
msgstr "Revelar PIN Root"

msgid "Remove Root PIN"
msgstr "Remover PIN Root"

msgid "PIN cannot be empty."
msgstr "O PIN não pode estar vazio."

msgid "PIN must contain digits only."
msgstr "O PIN deve conter apenas dígitos."

msgid "PIN must be between 4 and 8 digits."
msgstr "O PIN deve ter entre 4 e 8 dígitos."

msgid "Root PIN saved."
msgstr "PIN Root salvo."

msgid "Root PIN updated."
msgstr "PIN Root atualizado."

msgid "Root PIN is not set."
msgstr "O PIN Root não está definido."

msgid "The Root PIN will appear on the Kindle screen. Continue?"
msgstr "O PIN Root aparecerá na tela do Kindle. Continuar?"

msgid "Reveal"
msgstr "Revelar"

msgid "Root PIN: %1"
msgstr "PIN Root: %1"

msgid "Remove the saved Root PIN from this device?"
msgstr "Remover o PIN Root salvo deste dispositivo?"

msgid "Remove"
msgstr "Remover"

msgid "Root PIN removed."
msgstr "PIN Root removido."
